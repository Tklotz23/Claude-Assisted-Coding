# ODE system for ABC flow
def ABC_ODE(t, x, A, B, C):
    """ABC flow differential equations"""
    dxdt = np.array([
        A * np.sin(x[2]) + C * np.cos(x[1]),
        B * np.sin(x[0]) + A * np.cos(x[2]),
        C * np.sin(x[1]) + B * np.cos(x[0])
    ])
    return dxdt

# Generate random initial conditions
def rand_total(n, num_samples=10):
