def plot_implicit_surface(func, bounds, resolution=50, level=0, ax=None, **kwargs):
    """
    Plot implicit surface using marching cubes algorithm.
    Replaces MATLAB's fimplicit3.
    
    Parameters:
    -----------
    func : callable
        Function f(x,y,z) where surface is at f(x,y,z) = level
    bounds : list
        [xmin, xmax, ymin, ymax, zmin, zmax]
    resolution : int
        Grid resolution for each dimension
    level : float
        Isosurface level (default 0)
    ax : matplotlib axis
        3D axis to plot on
    **kwargs : dict
        Additional arguments for plot_trisurf
    """
    if ax is None:
        fig = plt.figure()
        ax = fig.add_subplot(111, projection='3d')
    
    # Create 3D grid
    x = np.linspace(bounds[0], bounds[1], resolution)
    y = np.linspace(bounds[2], bounds[3], resolution)
    z = np.linspace(bounds[4], bounds[5], resolution)
    X, Y, Z = np.meshgrid(x, y, z, indexing='ij')
    
    # Evaluate function on grid
    F = func(X, Y, Z)
    
    # Use marching cubes to find surface
    try:
        verts, faces, normals, values = measure.marching_cubes(F, level=level, spacing=(
            (bounds[1]-bounds[0])/resolution,
            (bounds[3]-bounds[2])/resolution,
            (bounds[5]-bounds[4])/resolution
        ))
        
        # Shift vertices to correct position
        verts[:, 0] += bounds[0]
        verts[:, 1] += bounds[2]
        verts[:, 2] += bounds[4]
        
        # Plot surface
        mesh = ax.plot_trisurf(verts[:, 0], verts[:, 1], faces, verts[:, 2],
                               **kwargs)
        
        return mesh
    except (ValueError, RuntimeError) as e:
        print(f"Warning: Could not generate surface - {e}")
        return None

